{
    "openapi": "3.1.0",
    "info": {
        "title": "RFQ Intelligence & Supplier Discovery API",
        "description": "Automated RFQ data extraction and hybrid supplier search engine.",
        "version": "2.0.0"
    },
    "paths": {
        "/": {
            "get": {
                "summary": "Root",
                "operationId": "root__get",
                "responses": {
                    "200": {
                        "description": "Successful Response",
                        "content": {
                            "application/json": {
                                "schema": {}
                            }
                        }
                    }
                }
            }
        },
        "/health": {
            "get": {
                "summary": "Health Check",
                "operationId": "health_check_health_get",
                "responses": {
                    "200": {
                        "description": "Successful Response",
                        "content": {
                            "application/json": {
                                "schema": {}
                            }
                        }
                    }
                }
            }
        },
        "/extract-pdf": {
            "post": {
                "tags": [
                    "Extraction"
                ],
                "summary": "Extract Pdf",
                "description": "Direct PDF upload endpoint. \nAccepts raw multipart/form-data. Base64 encoding NOT required.",
                "operationId": "extract_pdf_extract_pdf_post",
                "requestBody": {
                    "content": {
                        "multipart/form-data": {
                            "schema": {
                                "$ref": "#/components/schemas/Body_extract_pdf_extract_pdf_post"
                            }
                        }
                    },
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "Successful Response",
                        "content": {
                            "application/json": {
                                "schema": {}
                            }
                        }
                    },
                    "422": {
                        "description": "Validation Error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/HTTPValidationError"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/discovery": {
            "post": {
                "tags": [
                    "Discovery"
                ],
                "summary": "Hybrid Search",
                "description": "Hybrid search endpoint.\n- strict_mode=true: Excludes suppliers not meeting criteria.\n- strict_mode=false: Includes all suppliers, scored with match bonus.",
                "operationId": "hybrid_search_discovery_post",
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/SearchRequest"
                            }
                        }
                    },
                    "required": true
                },
                "responses": {
                    "200": {
                        "description": "Successful Response",
                        "content": {
                            "application/json": {
                                "schema": {}
                            }
                        }
                    },
                    "422": {
                        "description": "Validation Error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/HTTPValidationError"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/ingest": {
            "post": {
                "summary": "Trigger Ingest",
                "description": "Manual data ingestion trigger.",
                "operationId": "trigger_ingest_ingest_post",
                "parameters": [
                    {
                        "name": "csv_path",
                        "in": "query",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "title": "Csv Path"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Successful Response",
                        "content": {
                            "application/json": {
                                "schema": {}
                            }
                        }
                    },
                    "422": {
                        "description": "Validation Error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/HTTPValidationError"
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "Body_extract_pdf_extract_pdf_post": {
                "properties": {
                    "file": {
                        "type": "string",
                        "contentMediaType": "application/octet-stream",
                        "title": "File"
                    }
                },
                "type": "object",
                "required": [
                    "file"
                ],
                "title": "Body_extract_pdf_extract_pdf_post"
            },
            "HTTPValidationError": {
                "properties": {
                    "detail": {
                        "items": {
                            "$ref": "#/components/schemas/ValidationError"
                        },
                        "type": "array",
                        "title": "Detail"
                    }
                },
                "type": "object",
                "title": "HTTPValidationError"
            },
            "SearchRequest": {
                "properties": {
                    "query": {
                        "type": "string",
                        "title": "Query"
                    },
                    "certifications": {
                        "items": {
                            "type": "string"
                        },
                        "type": "array",
                        "title": "Certifications",
                        "default": []
                    },
                    "regulatory": {
                        "items": {
                            "type": "string"
                        },
                        "type": "array",
                        "title": "Regulatory",
                        "default": []
                    },
                    "strict_mode": {
                        "type": "boolean",
                        "title": "Strict Mode",
                        "default": true
                    },
                    "top_k": {
                        "type": "integer",
                        "title": "Top K",
                        "default": 5
                    }
                },
                "type": "object",
                "required": [
                    "query"
                ],
                "title": "SearchRequest"
            },
            "ValidationError": {
                "properties": {
                    "loc": {
                        "items": {
                            "anyOf": [
                                {
                                    "type": "string"
                                },
                                {
                                    "type": "integer"
                                }
                            ]
                        },
                        "type": "array",
                        "title": "Location"
                    },
                    "msg": {
                        "type": "string",
                        "title": "Message"
                    },
                    "type": {
                        "type": "string",
                        "title": "Error Type"
                    },
                    "input": {
                        "title": "Input"
                    },
                    "ctx": {
                        "type": "object",
                        "title": "Context"
                    }
                },
                "type": "object",
                "required": [
                    "loc",
                    "msg",
                    "type"
                ],
                "title": "ValidationError"
            }
        }
    }
}